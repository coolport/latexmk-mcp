{
  "compilerOptions": {
    /* Base environment */
    "lib": ["ESNext"],
    "target": "ESNext",
    "moduleDetection": "force",
    "allowJs": false,

    /* Building for npm */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "sourceMap": true,
    "declaration": true,
    "noEmit": false, 

    /* Best practices */
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    /* Project structure */
    "rootDir": "src"
  },
  "include": ["src/**/*"]
}
